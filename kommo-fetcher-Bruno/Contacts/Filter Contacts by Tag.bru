meta {
  name: Filter Contacts by Tag
  type: http
  seq: 5
}

get {
  url: {{base_url}}/api/v4/contacts?filter[tags][]=candidato-link-inscricao
  body: none
  auth: bearer
}

auth:bearer {
  token: {{kommo_token}}
}

headers {
  User-Agent: insomnia/12.6.0
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
